AREA_TO_PROCESS_GEOJSON_FILEPATH=target.geojson

DB_USER=sf_search
DB_PASSWORD=sf_search_dev_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sf_search
DB_DRIVER=postgresql+psycopg

NATS_URL=nats://localhost:4222
PANO_DOWNLOAD_STREAM=PANO_DOWNLOADS
PANO_DOWNLOAD_SUBJECT=pano.download.requested
PANO_PROCESSING_STREAM=PANO_PROCESSING
PANO_PROCESSING_SUBJECT=pano.processing.requested
PANO_EMBEDDING_STREAM=PANO_EMBEDDING
PANO_EMBEDDING_SUBJECT=pano.embedding.requested
PANO_DOWNLOADER_CONSUMER=pano-downloader
PANO_PROCESSING_CONSUMER=pano-processor
PANO_EMBEDDING_CONSUMER=pano-embedder

MAX_DOWNLOADER_QUEUE_DEPTH=1000
PANO_DOWNLOAD_CONCURRENCY=5
PANO_DOWNLOAD_STORAGE_DIR=.local/panoramas
MAX_PROCESSING_QUEUE_DEPTH=50

PANO_VIEWSETS_DIR=../../docs/data/viewsets
PANO_VIEW_STORAGE_DIR=.local/panorama-views
PANO_PROCESSING_CONCURRENCY=4
PANO_VIEW_MAX_RENDER_CONCURRENCY=4
PANO_VIEW_RENDER_SCALE=2
PANO_VIEW_OUTPUT_FORMAT=jpeg
PANO_VIEW_JPEG_QUALITY=95
MAX_EMBEDDING_QUEUE_DEPTH=100

PANO_EMBEDDING_CONCURRENCY=1
EMBEDDING_MODEL_PROVIDER=transformers
EMBEDDING_MODEL_ID=google/siglip2-so400m-patch14-384
EMBEDDING_MODEL_REVISION=main
EMBEDDING_PREPROCESS_VERSION=siglip2-384-rgb-v1
EMBEDDING_DIMENSION=1152
EMBEDDING_DTYPE=float16
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=1
EMBEDDING_VECTOR_STORE_DIR=.local/embedding-indexes

LOG_LEVEL=INFO
SERVICE_IDLE_SLEEP_SECONDS=5
